function mod_info_island_init(){
	register_card_info_island("gaia","基础能力：当自身三行内出现敌人时，每隔[攻击间隔]秒，就会发射两枚\n毁灭巨石，在本行对应的敌人位置造成3*3范围的灰烬爆炸效果，造成\n[攻击力]点伤害。\n *星级影响[攻击间隔]，技能影响[冷却时间]。\n\n三转能力：攻击力提高，眩晕并初始瞬发。\n\n四转能力：增加1发子弹。\n\n终转能力：爆炸范围扩大至5x5。")
	register_card_info_island("aurora","基础能力：为本行投掷类卡片增伤,倍率为[攻击力]/100。\n *星级影响[攻击力]，技能影响[冷却时间]。\n\n三转能力：死亡后造成3x3爆炸。\n\n四转能力：[攻击力]额外增加30%。\n\n终转能力：增伤范围提升至三行，非本行加成为原来的20%。")
	register_card_info_island("zhurong","基础能力：当前方攻击范围内出现敌人时，每隔[攻击间隔]秒，就会投出\n高温n球，点燃身前3x3的地面，对上面的敌人持续造成[攻击力]的伤害。\n-祝融的射程为4格\n-每发子弹总计造成10次[攻击力]的伤害\n *星级影响[攻击力]，技能影响[攻击间隔]。\n\n三转能力：[攻击力]额外提升30%，射程增加一格。\n\n四转能力：点燃范围扩大到5x5。\n\n终转能力：[攻击力]额外提升45%，点燃范围扩大到7x5。")
	register_card_info_island("rig","基础能力：当前方出现敌人时，每隔[攻击间隔]秒，就会像前方5个方向\n发射穿透子弹，对穿过的敌人造成[攻击力]的伤害。\n -场上每存在一个里格，自身的[能量消耗]就会增加50点。\n *星级影响[攻击力]，技能影响[攻击间隔]。\n\n三转能力：[攻击力]额外提升10%，能量守恒。\n\n四转能力：攻击力根据场上里格的数量提升。\n\n终转能力：每次攻击额外发射一轮子弹。")
	register_card_info_island("brahma","基础能力：在3x3范围内复制两张上一次放下的卡片，优先选择中心和上下\n两格。\n *星级影响[冷却时间]，技能无影响。\n\n三转能力：放置造成5x5灰烬爆炸。\n\n四转能力：额外复制一张卡片。\n\n终转能力：未开放。")
	register_card_info_island("clotho","基础能力：放下后一段时间为3x3范围内的所有卡片随机提高或降低星级，\n最高16星，最低0星。\n *星级影响[冷却时间]，技能无影响。\n\n三转能力：优化升星概率，必定升星。\n\n四转能力：优化升星概率，影响范围扩大到5x5。\n\n终转能力：优化升星概率，影响范围扩大到7x5。")
	register_card_info_island("warm_birds","基础能力：放置1秒后立即生产三朵价值为[火苗产量]的火苗，随后每隔[攻\n击间隔]秒，就会产出三朵火苗。\n *星级影响[攻击间隔]，技能影响[火苗产量]。\n\n一转能力：一次可产出四朵火苗。\n\n二转能力：一次可产出五朵火苗，冷却时间减半。")
	register_card_info_island("sea_star","基础能力：场上出现敌人时，每隔[攻击间隔]秒向五个触角的方向发射一枚\n伤害为[攻击力]的炭烧海星子弹。\n *星级影响[攻击力]，技能影响[攻击间隔]。\n\n一转能力：能量消耗减半。\n\n二转能力：每个方向额外增加一枚子弹，子弹可以反弹。")
	register_card_info_island("tanghulu","基础能力：当场上出现空中敌人时，每隔[攻击间隔]秒发射一颗追踪的糖葫\n芦炮弹，对敌人造成[攻击力]的伤害。\n *星级影响[攻击力]，技能影响[攻击间隔]。\n\n一转能力：[攻击力]额外增加20%。\n\n二转能力：一次发射两颗追踪炮弹。")
	register_card_info_island("cold_drew","基础能力：当场上出现敌人时，每隔[攻击间隔]秒根据敌人数量发射至多四\n颗冰块子弹打击敌人，对敌人造成[攻击力]的伤害。\n *星级影响[攻击力]，技能影响[攻击间隔]。\n\n一转能力：可以发射的子弹增加一枚，每颗子弹获得20%溅射。\n\n二转能力：固定发射6枚冰块子弹，可集火。")
	register_card_info_island("berry_dessert","基础能力：为自身周围3x3范围内的追踪类卡片增伤，倍率为[攻击力]/100。\n *星级影响[攻击力]，技能影响[冷却时间]。\n\n一转能力：增伤范围扩大至5x5。\n\n二转能力：[攻击力]固定增加30。")
	register_card_info_island("grilled_lizard_pult","基础能力：当前方一行出现敌人时，每隔[攻击间隔]秒，就会投掷一个爆弹，\n爆弹会对主目标造成等同于[攻击力]的伤害，并对3*3范围内的其他目标造\n成35%的溅射伤害。\n *星级影响[攻击力]，技能影响[攻击间隔]。\n\n一转能力：[攻击力]额外增加45%。\n\n二转能力：每次攻击可投掷两个爆弹。")
	register_card_info_island("blueberry_tower","基础能力：为本行投掷类卡片增伤,倍率为[攻击力]/100。\n *星级影响[攻击力]，技能影响[冷却时间]。")
	register_card_info_island("donut","基础能力：当前方一行出现敌人时，每隔[攻击间隔]秒，就会根据敌人类型\n连续发射两颗对空/对地甜甜圈子弹，甜甜圈子弹会穿过障碍，对敌人造成\n等同于[攻击力]的伤害。\n *星级影响[攻击力]，技能影响[攻击间隔]。\n\n一转能力：[能量消耗]子弹附加3x3范围25%溅射。\n\n二转能力：每次攻击额外射出一发子弹。")
	register_card_info_island("spoon_rabbit","基础能力：当前方三行出现敌人时，每隔[攻击间隔]秒，就会投掷三颗爆\n炸萝卜，每行一颗，爆炸萝卜会对主目标造成等同于[攻击力]的伤害，并\n对3*3范围内的其他目标造成35%的溅射伤害。\n *星级影响[攻击力]，技能影响[攻击间隔]。\n\n一转能力：中路额外增加一发子弹，共4发。\n\n二转能力：侧路额外增加两发子弹，共6发。")
	register_card_info_island("firework_dragon_real","基础能力：放下后经过[准备时间]产出6朵价值[火苗产量]的火苗。\n *星级影响[火苗产量]，技能影响[准备时间]。\n\n一转能力：放下后立刻返还种植消耗的火苗。\n\n二转能力：额外产出6朵火苗。")
	register_card_info_island("hspeed_juicer","基础能力：为自身周围3x3范围内的喷壶类卡片增伤，倍率为[攻击力]/100。\n *星级影响[攻击力]，技能影响[冷却时间]。\n\n一转能力：[攻击力]固定增加25。\n\n二转能力：增伤范围扩大至5x5。")

    register_card_info_island("shuangzi","基础能力：放置后生产四朵价值为[火苗产量]的火苗，随后每隔[攻\n击间隔]秒，就会产出四朵火苗。\n *星级影响[攻击间隔]，技能影响[火苗产量]。\n\n一转能力：冷却时间减少。\n\n二转能力：一次可产出六朵火苗，冷却时间减少。")
    register_card_info_island("sheshou",  "基础能力：同时向正前方三行发射4发强力箭，中间2发，两边各1发\n，威力巨大！\n*星级影响[攻击力]，技能影响[攻击间隔]。\n\n一转能力：能量守恒(不＋)。\n\n二转能力：攻击次数增加，每次攻击向前方三行各射\n出2发（共6发）强力子弹。");
	register_card_info_island("athena","基础能力：普通能力：高频率发射激光武器，全屏跟踪轰炸，强力范围伤害。\n *星级影响[攻击力]，技能影响[攻击间隔]。\n\n一转能力：能量守恒（不+）。\n\n二转能力：连射两发激光。")
	register_card_info_island("tiancheng","基础能力：对前后各发射3发强力子弹，威力与实力的象征。\n *星级影响[攻击力]，技能影响[攻击间隔]。\n\n一转能力：能量守恒（不+）。\n\n二转能力：前后各增加1发子弹。")
	register_card_info_island("shuangyu","基础能力：投掷两发强力冰鱼并产生溅射伤害40%,威力强大。\n *星级影响[攻击力]，技能影响[攻击间隔]。\n\n一转能力：能量守恒，[能量消耗]不再增加。\n\n二转能力：子弹威力提升35%。")
	register_card_info_island("juxie","基础能力：扔出4发强力大钳子，全屏跟踪，无死角攻击。。\n *星级影响[攻击力]，技能影响[攻击间隔]。\n\n一转能力：能量守恒（不+）。\n\n二转能力：增加2发子弹。")
	register_card_info_island("shizi","基础能力：连续快速向周边发出猛烈攻击，海陆空交通管制。\n *星级影响[攻击力]，技能影响[攻击间隔]。\n\n一转能力：能量守恒（不+）。\n\n二转能力：范围威力增加25%。")
	register_card_info_island("jinniu","基础能力：凡是穿透它能变成火弹的子弹，威力伤害超强提升，冰弹除外。\n *星级影响[攻击提升倍率]，技能影响[冷却时间]。\n\n一转能力：耗能减少50。\n\n二转能力：威力增加12%")
	register_card_info_island("chunv","基础能力：保护被他罩住的卡片，对啃它的老鼠造成一定伤害，体力更高。\n *星级影响[生命值]，技能影响[冷却时间]。\n\n一转能力：爆破伤害增加30%。\n\n二转能力：爆破范围增加到5*5")
	register_card_info_island("tianxie","基础能力：猩红毒针，分裂式穿透攻击，对一行连续4格造成100%伤害。\n *星级影响[攻击力]，技能影响[攻击间隔]。\n\n一转能力：能量守恒（不+）。\n\n二转能力：增加一发毒针")
	register_card_info_island("baiyang","基础能力：释放一直白羊精灵，对陆地上的小老鼠造成毁灭性伤害。\n *星级影响[冷却时间]，技能影响[攻击力]。\n\n一转能力：降低能耗至200点。\n\n二转能力：增加上下两行，对三行鼠军造成伤害")
	register_card_info_island("mojie","基础能力：对范围内造成巨大冰暴伤害，老鼠持续减速扣血，卡片存在一定\n时间后消失。\n *星级影响[攻击力]，技能影响[冷却时间]。\n\n一转能力：[攻击间隔]减半。\n\n二转能力：增加攻击范围")
	register_card_info_island("corn_shooter","基础能力：当前方一行内出现敌人时，就会每隔[攻击间隔]秒直线发射三颗\n伤害为[攻击力]的玉米（可过火）。\n *星级影响[攻击力]，技能影响[冷却时间]。\n\n一转能力：增加三发子弹且能量守恒（不+）。\n\n二转能力：子弹威力增加30%。")
	
	register_card_info_island("sun_god","基础能力：产能突破极限，每隔一段\n[攻击间隔]产出6多火苗，放置后立即生产。\n *星级影响[攻击间隔]，技能影响[火苗产量]。\n\n三转能力：一次生产8朵火苗，冷却与耗火略微降低。\n\n四转能力：一次生产10朵火苗，冷却与耗火进一步降低。\n\n终转能力：一次生产12朵火苗，冷却与耗火大幅降低，首次产量翻倍")
	register_card_info_island("moon_god","基础能力：连续发射6发全屏追踪型攻击的子弹，海陆空兼顾。\n *星级影响[攻击力]，技能影响[攻击间隔]。\n\n三转能力：增加1发子弹。\n\n四转能力：每组首发的子弹变身超级子弹,\n超级子弹拥有200%伤害并对3×3范围内敌人造成75%溅射。\n\n终转能力：增加一发子弹，场上每个月神增加5%伤害，最高至145%")
	register_card_info_island("war_god","基础能力：前后方分别同时发射4发强力子弹，一共8发。\n *星级影响[攻击力]，技能影响[攻击间隔]。\n\n三转能力：前后增加1发子弹。\n\n四转能力：前方每四轮额外射出一发超级子弹，超级子弹拥有800%攻击力。\n\n终转能力：后方每四轮也额外射出一发超级子弹，超级子弹拥有1200%攻击力")
	register_card_info_island("hera","基础能力：保护被罩的卡片，反伤啃咬它的老鼠，消失后对5×5范围造成\n一次等同剩余生命值的物理伤害与等同最大生命值的爆炸伤害。\n *星级影响[生命值]，技能影响[冷却时间]。\n\n三转能力：增加25%体力。\n\n四转能力：给被保护的卡片增加1000体力。\n\n终转能力：一次种植3个，优先正上与正下方")
	register_card_info_island("thor","基础能力：连续发出2发带有强力溅射伤害40%和减速效果的冰锤。\n *星级影响[攻击力]，技能影响[攻击间隔]。\n\n三转能力：增加1发冰锤，但攻击力降低，总伤害增加20%。\n\n四转能力：溅射伤害提升至45%，每3轮额外投出1发超级子弹，\n超级子弹拥有200%伤害。\n\n终转能力：每轮增加一发超级子弹，溅射伤害提升至100%")
	register_card_info_island("poseidon","基础能力：连续向周围5*5格发出2发水波攻击，范围伤害能力高度提升。\n *星级影响[攻击力]，技能影响[攻击间隔]。\n\n三转能力：攻击力提升20%并附加减速效果。\n\n四转能力：增加1发水波攻击。\n\n终转能力：范围提升至7×5，总伤害提升85%")
	register_card_info_island("love_god","基础能力：向正前方三行分别射出2发子弹，一共6发。\n *星级影响[攻击力]，技能影响[攻击间隔]。\n\n三转能力：中路增加1发子弹。\n\n四转能力：侧路各增加1发子弹。\n\n终转能力：每四轮额外发射三发超级子弹，\n超级子弹拥有300%伤害，且可穿透敌人与障碍")
	
	register_card_info_island("zeus","基础能力：全屏发射两发强力闪电攻击，造成3×3强力范围伤害。\n *星级影响[攻击力]，技能影响[攻击间隔]。\n\n三转能力：攻击力提升20%。\n\n四转能力：增加一发闪电。\n\n终转能力：增加两发闪电，范围变为5×5。")
	register_card_info_island("ghost_god","基础能力：向五个方向分别发射一枚强力子弹。\n *星级影响[攻击力]，技能影响[攻击间隔]。\n\n三转能力：增加一发附带减速和穿透的次级子弹，但伤害仅有20%。\n\n四转能力：攻击力提升，再增加一发次级子弹。\n\n终转能力：所有子弹变为次级子弹，但次级子弹现在拥有100%伤害。")
	register_card_info_island("ice_god","基础能力：召唤冰晶，攻击全屏8个敌人，附加减速。\n *星级影响[攻击力]，技能影响[攻击间隔]。\n\n三转能力：耗能减少，冰晶带有3程3的40%溅射伤害。\n\n四转能力：攻击力提升，攻击数量+2。\n\n终转能力：攻击力大幅提升，攻击数量＋2。")
	register_card_info_island("odin","基础能力：向前方发射两发穿透短矛子弹。\n *星级影响[攻击力]，技能影响[攻击间隔]。\n\n三转能力：攻击力提升25%。\n\n四转能力：增加1发子弹。\n\n终转能力：再次增加1发子弹。")
	register_card_info_island("fire_god","基础能力：穿过后变成高温子弹，并且伤害能力得到飞升，冰弹无效。\n *星级影响[攻击提升倍率]，技能影响[冷却时间]。\n\n三转能力：伤害再度提升20%。\n\n四转能力：被火子弹击中后，对当前格的敌人附加50%火焰群伤\n\n终转能力：增幅倍率再次提升20%，被火子弹击中后，对3×3范围内的敌人\n附加80%火焰群伤，\n*被直接击中的目标也会受到该伤害。")
	register_card_info_island("water_god","基础能力：将大多数命中自己的直射子弹反弹至相反的方向，并使它们的伤\n害增加[攻击力]点。每个子弹只能被反弹一次。\n *星级影响[攻击力]和[生命值]，技能影响[冷却时间]。\n\n三转能力：[能量消耗]降低至75。\n\n四转能力：[攻击力]额外增加。")
	register_card_info_island("power_god","基础能力：发射两发强力子弹追踪攻击空中鼠军\n\n *星级影响[攻击力]，技能影响[攻击间隔]。\n\n三转能力：威力提升35%，定身加强。\n\n四转能力：增加1发子弹。\n\n终转能力：再增加一发子弹且触发灰烬效果。")
	register_card_info_island("sheng_huo","基础能力：施展火焰术，向前方3行释放神圣穿透型火焰，灼烧沿途鼠军\n\n *星级影响[攻击力]，技能影响[攻击间隔]。\n\n三转能力：伤害大幅度提升, 几率眩晕,灰烬效果。\n\n四转能力：可伤害老鼠类型增加空中和地下。\n\n终转能力：同类卡片可提升伤害，几率产生暴烈一击。")
	register_card_info_island("save_god","基础能力：化身为4条灵鱼，冲撞沿途遇到的老鼠\n\n *星级影响[冷却时间]，技能影响[攻击力]。\n\n三转能力：无需格子。\n\n四转能力：增加2条灵鱼，几率清理障碍。\n\n终转能力：增加2条灵鱼，清理遇到的路障。")
    register_card_info_island("joker","基础能力：连续发射3发带有溅射效果的子弹，先后攻击本行\n\n空、地、水陆老鼠\n\n *星级影响[攻击力]，技能影响[攻击间隔]。\n\n三转能力：溅射伤害提升，死亡蝙蝠效果。\n\n四转能力：增加1发子弹。\n\n终转能力：溅射伤害提升。")
	register_card_info_island("ymir","基础能力：向前方三行投出共6发巨锤，带有45%溅射伤害。\n *星级影响[攻击力]，技能影响[攻击间隔]。\n\n三转能力：中路增加一发巨锤，攻击力提升10%，溅射伤害提升至50%。\n\n四转能力：侧路各增加一发巨锤，攻击力再提升10%，击杀附带灰烬效果\n\n终转能力：每路增加一发巨锤，攻击力再额外提升20%")
    register_card_info_island("beef_hot_pot","基础能力：当右侧四格内出现敌人时，每隔[攻击间隔]秒，就会向右侧\n持续喷射火焰，火焰会持续伤害范围内的所有敌人并穿透手持防具。\n *星级影响[攻击力]，技能影响[攻击间隔]。\n\n一转能力：[攻击力]额外增加20%。\n\n二转能力：攻击距离扩大至5格。")
	register_card_info_island("shengjian_pot","基础能力：当右侧五格内出现敌人时，每隔[攻击间隔]秒，就会向右侧\n投掷出生煎，生煎落地后会产生十字范围火焰，持续伤害范围内的所\n有敌人并穿透手持防具。 *星级影响[攻击力]，技能影响[攻击间隔]。\n\n一转能力：[攻击力]额外增加20%。\n\n二转能力：火焰范围扩大至3×3。")
	register_card_info_island("spicy_pot","基础能力：当右侧3×4范围内出现敌人时，每隔[攻击间隔]秒，就会向右侧\n发出火焰墙，火焰墙会伤害范围内的所有敌人并穿透手持防具。\n *星级影响[攻击力]，技能影响[攻击间隔]。\n\n一转能力：[攻击力]额外增加20%。\n\n二转能力：攻击距离扩大至3×5格。")
	register_card_info_island("chaomian","基础能力：快速猛击前2格敌人，每隔[攻击间隔]秒，\n *星级影响[攻击力]，技能影响[攻击间隔]。\n\n一转能力：[攻击力]额外增加20%。\n\n二转能力：攻击距离扩大至3格。")

}